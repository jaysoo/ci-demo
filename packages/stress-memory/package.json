{
  "name": "@tanstack-start-template/stress-memory",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "sourceRoot": "packages/stress-memory/src",
    "tags": [
      "scope:shared",
      "type:util"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "cache": false,
        "options": {
          "command": "node src/hog.mjs",
          "cwd": "packages/stress-memory"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "echo 'lint ok'",
          "cwd": "packages/stress-memory"
        }
      }
    }
  }
}
