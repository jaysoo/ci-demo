{
  "name": "@tanstack-start-template/ui",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "nx": {
    "sourceRoot": "packages/ui/src",
    "tags": [
      "scope:shared",
      "type:ui"
    ],
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc --noEmit",
          "cwd": "packages/ui"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "echo 'lint ok'",
          "cwd": "packages/ui"
        }
      }
    }
  }
}
